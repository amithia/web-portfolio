{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/timeline", "destination": "/milestones", "permanent": true },
    { "source": "/work/google-ux-cert", "destination": "/beyond-work/google-ux-design-certificate", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/home" },
    { "source": "/work/:slug", "destination": "/templates/work-detail?id=:slug" },
    { "source": "/beyond-work/:slug", "destination": "/templates/beyond-work-detail?id=:slug" }
  ]
}
